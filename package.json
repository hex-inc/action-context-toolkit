{
  "name": "github-context-toolkit",
  "version": "1.0.0",
  "description": "Upload external context to Hex",
  "homepage": "https://github.com/hex/github-context-toolkit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hex/github-context-toolkit.git"
  },
  "scripts": {
    "test": "vitest",
    "lint": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
