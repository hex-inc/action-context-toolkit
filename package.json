  "license": "MIT",
  "devDependencies": {
    "@swc/jest": "^0.2.39",
    "@types/node": "^25.2.3",
    "@types/picomatch": "^4.0.2",
    "esbuild": "^0.27.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "picomatch": "^4.0.3",
    "zod": "^4.3.6"
  }
}
